{
    "id": 52134,
    "version": 4,
    "title": "Manga-shi",
    "host": "https://manga-shi.org",
    "public_link": "https://manga-shi.org/manga",
    "folder": "manga-shi",
    "name": "manga-shi",
    "chapters_order": true,
    "language": "ru",
    "encoding": "utf-8",

    "icon_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/img/manga-shi.png",
    "self_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/parsers/manga-shi.json",
    "self_link2": "https://fant.my1.ru/mwparser/mwx/json/manga-shi.json",
    "catalog_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/catalogs/manga-shi.zip",
    "file_type": "sqlite",
    "author": {
        "name": "MWX Team",
        "email": "fant-net@ya.ru"
    },
    
	

	
    "manga_search_complete": {
       "headers": {
			"Accept": "*/*",
            "Referer": "https://manga-shi.org/",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" 
			},
        "search_link": "https://manga-shi.org/catalog/?q=$query$&sort=added&status=&type=&year=&age_rating=&chapters_min=&chapters_max=",
        "query_type": "GET",
        "add_manga": {
            "start": ">Каталог манги</h1>",
            "end": "<footer",
            "next": "<div class=\"media-skeleton\">",
			
            "link": {
                "before": "<div class=\"media-skeleton-icon\">",
                "token1": "href=\"",
                "token2": "\""
            },

            "title": {
				"after": "<div class=\"media-skeleton-icon\">",
                "token1": "title=\"",
                "token2": "\""
            },
            "uniq": {
				"before": "<div class=\"media-skeleton-icon\">",
                "token1": "href=\"/manga/",
                "token2": "\""
            },
			
            "cover": {
				
				"after": "<div class=\"media-skeleton-icon\">",
                "token1":"<img src=\"",
                "token2":"\""
            }
            
        }
    },
    "manga_list_complete": {
         "headers": {
			"Accept": "*/*",
            "Referer": "https://manga-shi.org/",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" 
			},
        "iterator": {
            "base_url": "https://manga-shi.org/catalog/?sort=rating&status=&type=&year=&age_rating=&chapters_min=&chapters_max=&q=&page=",
            "append_nums": {
                "from": 1,
                "to": 30
            }
        },
        "add_manga": {
            "start": ">Каталог манги</h1>",
            "end": "<footer",
            "next": "<div class=\"media-skeleton\">",
			
            "link": {
                "before": "<div class=\"media-skeleton-icon\">",
                "token1": "href=\"",
                "token2": "\""
            },

            "title": {
				"after": "<div class=\"media-skeleton-icon\">",
                "token1": "title=\"",
                "token2": "\""
            },
            "uniq": {
				"before": "<div class=\"media-skeleton-icon\">",
                "token1": "href=\"/manga/",
                "token2": "\""
            }
        },
	    
        "rating_auto_inc": {
            "start": "40000",
            "inc": -1
        }
    },
    "manga_complete": {
		
        "headers": {
			"Accept": "*/*",
            "Referer": "https://manga-shi.org",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" 
			},
        
		
		
		"title":{
         "skip":"<meta id=\"og-title\"", 
         "token1":"content=\"",
         "token2":"\"" ,
		  "replace": [
				{"match": "Манга","text": ""},
				{"match": "Манхва","text": ""},
				{"match": "/","text": "|"},
				{ "clear_escape": true },
				{"match":"<.*?>","text":""}

				]},
				
		
        
        "uniq": {
            "token1": "<meta id=\"og-url\" property=\"og:url\" content=\"https://manga-shi.org/manga/",
            "token2": "\">"
        },
        "cover": {
			"skip": "<meta id=\"og-image\" property=\"og:image\"",
            "token1":"content=\"",
            "token2":"\"",
				    "replace": { "prefix": "https://manga-shi.org"} 
        },
        "summary": {
			"skip": "class=\"text-zinc-400 text-xs leading-relaxed",
            "token1":"\">",
            "token2":"</div>",
            "replace": [
			    { "clear_escape": true },
                {
                    "match": "u003Cp",
                    "text": ""
                },
                {
                    "match": "u003E",
                    "text": ""
                },
                {
                    "match": "u003C",
                    "text": ""
                },
                {
                    "match": "<.*?>",
                    "text": ""
                },
                {
                    "match": "u002Fp",
                    "text": ""
                },

                {
                    "match": "&quot;",
                    "text": "'"
                }
            ]
        },
       
	   
	   "author":      { "skip": ">Автор:", "token1": "</span>", "token2": "</div>",
	                        "replace": {  "match": "<.*?>", "text": "" } 
					},
        "status": {
            "complete": {
                "start": "<main id=\"page-content\"",
                "end": "<div class=\"flex-1 min-w-0\">",
                "values": ["Закончен", "Переведена","Завершен","Сингл","Отменено","Завершено"]
            },
            "ongoing": {
                "start": "<main id=\"page-content\"",
                "end": "<div class=\"flex-1 min-w-0\">",
                "value": "Онгоинг"
            }
        },
        
       
		"add_tags": {
            "start": "class=\"flex flex-wrap gap-2 mb-10 sm:mb-12\">",
            "end": "</div>",
            "token1": "\">",
            "token2": "</"
        },
		
        "is_mature": {
            "values": ["Сэйнэн", "Эротика", "Юри", "Яой",">18+</div>",">Контент 18+<" ]
        },
		
		"need_auth": [
			"залогиненным",
			">18+</div>",
			"хентай"
		],
        
		"chapters_from_page": {
            "after": "<meta id=\"og-url\"",
            "token1": "content=\"",
            "token2": "\"",
            "replace": { "sufix": "chapters/?chapter_sort=latest&page=%%iterator_num%%"  },
            "iterator": {
                "base_url": "",
                "append_nums": {
                    "from": 1
                }
            }
        },
		
		
        "add_chapter": {
			"headers": {
			"Accept": "*/*",
            "Referer": "%%url%%",
			"User-Agent": "mangawatcherx"
			},
			
            "next": "<a",
            
			"link": {
                "token1": "href=\"",
                "token2": "\"",
				    "replace": { "prefix": "https://manga-shi.org"} 
            },
            "uniq": {
                "skip": "href=\"",
                "token1": "<span>",
                "token2": "</span>",
                "replace":{ "match": "/", "text": "_" }
            },
            "title": {
                "skip": "href=\"",
                "token1": "<span>",
                "token2": "</span>",
                "replace": [
                    {
                        "match": "<.*?>",
                        "text": ""
                    },
					{
                        "match": "&#039;",
                        "text": "'"
                    },
					{
                        "match": "&quot;",
                        "text": "\""
                    },
                    {
                        "match": "\u2014",
                        "text": "-"
                    }
                ]
            }
        }
    },
    "chapter_complete": {
         "headers": {
			"Accept": "*/*",
            "Referer": "https://manga-shi.org/",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" 
			},
        "add_images": {
            "start": "class=\"reader-page is-loaded\"",
			"after": "<img",
			
            "token1": "/media/",
            "token2": "\"",
            "end": "class=\"reader-ad reader-ad-end my-6\">",
            "replace": { "prefix": "https://manga-shi.org/media/" }
			
        }
    },
