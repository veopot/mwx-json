			 "Referer": "https://wamanga.ru/"
			},
			
            "start": "class=\"title-info-description",
            "end": "</swiper-container>",
            "next": "class=\"chapters-minimal-preview-slide",
			
            "link": {
				"after": "<a ",
                "token1": "href=\"../",
                "token2": "\"",
                "replace": {"prefix": "https://wamanga.ru/"  }
            },
            "uniq": {
				"after": "<a href=\"",
				"token1": "\">",
				"token2":  "</div>",
                "replace": {"match":"<.*?>","text":""}
            },
            "title": {
                "after": "<a href=\"",
				"token1": "\">",
				"token2":  "</div>",
                "replace": {"match":"<.*?>","text":""}
			}
        }
    },
