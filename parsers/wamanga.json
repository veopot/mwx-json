    "manga_list_complete": {
        "headers": { "Referer": "https://wamanga.ru/"}, 
		
		
		"iterator": "https://wamanga.ru/sitemap.xml",
		
        "add_manga": {
			"start": "<urlset",
			"end":   "</urlset>",
            "next": "<url>",
            "link": {
                "token1": "<loc>https://wamanga.ru/",
                "token2": "</loc>",
				    "replace": { "prefix": "https://wamanga.ru/"} 
			},
            "title": {
                "token1": "<loc>https://wamanga.ru/",
                "token2": "</loc>",
                "replace": [
                    {
                        "match": "manhwa/",
                        "text": ""
                    },
					{
                        "match": "manga/",
                        "text": ""
                    },
					{
                        "match": "manhua/",
                        "text": ""
                    }
                ]
            },
             "uniq": {
                "token1": "<loc>https://wamanga.ru/",
                "token2": "</loc>",
                "replace": [
                    {
                        "match": "manhwa/",
                        "text": ""
                    },
					{
                        "match": "manga/",
                        "text": ""
                    },
					{
                        "match": "manhua/",
                        "text": ""
                    }
                ]
            }
        },
	    
        "rating_auto_inc": {
            "start": "2000",
            "inc": -1
        }
    },
    "manga_complete": {
		
        "headers": {
        "accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7",
        "accept-language": "ru-RU,ru;q=0.9,en-US;q=0.8,en;q=0.7",
        "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36",
		"cookie": "access_token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjAwOGE2OWY4LTEwNzQtNDM5ZC1iMmI1LWQzNjc1NWRhOWZhNSIsInJvbGUiOiJ1c2VyIiwiaWF0IjoxNzc5MzYwOTEyLCJleHAiOjE3Nzk2MjAxMTJ9.oZ_MrDuEc4XMb29eWj0_CuLcius99dqvlqhWBGL9w7c"
        },
        
        "title": {
			"after": "<h1",
            "token1": "\">",
            "token2": "</",
            "replace": [
                {
                    "match": "\"",
                    "text": "'"
                },
                {
                    "match": "\\\\",
                    "text": ""
                }
            ]
        },
        
        "uniq": {
			"after": "property=\"canonical\"",
            "token1": "content=\"https://wamanga.ru",
            "token2": "/\"",
                "replace": {
                    "match": "/",
                    "text": "_"
                }
        },
		
		"author": { "skip": ">Автор оригинала</", "token1":"class=\"svelte-148miim\">", "token2": "</" },
		
		"cover": {
           "after": "property=\"og:image\"",
            "token1": "content=\"",
            "token2": "\""
        },
        "summary": {
            "token1": "<p class=\"title-info-description svelte-148miim\">",
            "token2": "</p>",
            "replace": [
			    { "clear_escape": true },
				{ "clear_html": true },
                {
                    "match": "u003Cp",
                    "text": ""
                },
                {
                    "match": "u003E",
                    "text": ""
                },
                {
                    "match": "u003C",
                    "text": ""
                },
                {
                    "match": "<.*?>",
                    "text": ""
                },
                {
                    "match": "u002Fp",
                    "text": ""
                },
                {
                    "match": "&quot;",
                    "text": "'"
                }
            ]
        },
        "need_auth": "авторизироваться",
		
		 "status": {
            "complete": {
                "start": ">Статус перевода</",
               "end": "</span></span>",
                "values": ["Закончен", "Переведена","Завершен","Сингл","Отменено","Окончено","Завершено"]
            },
            "ongoing": {
                 "start": ">Статус перевода</",
                "end": "</span></span>",
                "value": "Онгоинг"
            }
        },
        
        
        
        "add_tags": {
            "start": ">Жанры<",
            "end": "</div></div>",
            "token1": "\"><!---->",
            "token2": "<!----></"
        },
        "is_mature": {
