{
	"id": 40128,
	"version": 6,
	
	"title": "Rawkuma",
	"host": "https://rawkuma.com/",
	"public_link": "https://rawkuma.com/",
	"old_sites": ["rawkuma.com" ],
	
	
	"folder": "rawkuma",
	"name" : "rawkuma",
	"language": "jp",
	"is_paid": true,
	"skip_catalog_test": false,
	"icon_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/img/rawkuma.png",
	"self_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/parsers/rawkuma.json",
	"self_link2": "https://fant.my1.ru/mwparser/mwx/json/rawkuma.json",
	"catalog_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/catalogs/rawkuma.zip",
    "file_type": "sqlite",
	"author": {"name":"Veopot","email":"fant-net@ya.ru"},

	

	 "manga_search_complete": {		
		"search_link": "https://rawkuma.net/wp-admin/admin-ajax.php?nonce=2fd46782ae&action=search",
		
		"headers": {
		"accept": "*/*",
        "accept-language": "ru-RU,ru;q=0.9,en-US;q=0.8,en;q=0.7",
        "content-type": "application/x-www-form-urlencoded",
        "hx-current-url": "https://rawkuma.net/",
        "hx-request": "true",
        "hx-target": "searchModalContent",
        "origin": "https://rawkuma.net",
        "referer": "https://rawkuma.net/"
        },
		
		"form_data": { "query": "$query$" },
		"query_type": "POST",
        "add_manga": {
        
            
        "next":"<a",
        
		 "title": {
                "token1": "<h3 class=\"text-lg font-semibold line-clamp-2\">",
                "token2": "</h3>"
            },
            "link": {

                "token1": "href=\"",
                "token2": "\""
            },
            "uniq": {
                "token1": "href=\"https://rawkuma.net/manga/",
                "token2": "\""
            },
             "cover": {

                "token1": "src=\"",
                "token2": "\""
            },
            
            "summary":  {
                "token1": "<p class=\"text-gray-500 line-clamp-2\">",
                "token2": "</p>"
            }
        }
    },
   
   

	"manga_list_complete": {
		
		 
		"iterator": {
			"base_url": "https://rawkuma.net/manga-sitemap",
			"append_nums": {
				"from": 1,
				"to": 139,
				"step": 1,
				"sufix": ".xml"
			}
		},
		
		"add_manga": {
			"next": "<url>",
			"link":  { "token1": "<loc>", "token2": "</" },
			"title": { "token1": "<loc>https://rawkuma.net/manga/", "token2": "</",
				"replace": [{
						"match": "/",
						"text": ""
					},
					{
						"match": "\n",
						"text": " "
					},
					{
						"match": "-",
						"text": " "
					}
				] },
			"uniq": { "token1": "<loc>https://rawkuma.net/manga/", "token2": "</" }
		},
		"rating_auto_inc": {
			"start": "20000",
			"inc": -1
		}
	},

	"manga_complete": {
		"title": { "token1":"itemprop=\"name\">", "token2": "</",
                            "replace": { "match":"Raw","text":""} },
							
		"uniq": { "after": "<meta property=\"og:url\"", "token1":"content=\"https://rawkuma.net/manga/", "token2": "\"",
                            "replace": { "match":"Raw","text":""} },
		
		"author":      { "skip": "<span class=\"font-semibold\">Serialization", "token1": "</span>", "token2": "</div>",
                            "replace": { "match":"<.*?>","text":""}
						},
		
		"summary":     { "after": "<div data-show=\"false\" itemprop=\"description\" class=\"p-4 bg-secondary/50 rounded-lg hidden data-[show=true]:block break-words-force", 
		"token1": "\">", "token2": "</div>",
                            "replace": { "match":"<.*?>","text":" "} },
		
		
		"is_mature": {
		"start": "</head>",
		"end": "</html>",
			"values": [
			"href=\"https://rawkuma.net/genre/adult/", 
			"href=\"https://rawkuma.net/genre/lolicon/",
			"href=\"https://rawkuma.net/genre/mature/",
			"href=\"https://rawkuma.net/genre/yaoi/",
			"href=\"https://rawkuma.net/genre/yuri/",
			"href=\"https://rawkuma.net/genre/seinen/"
			]
		},
		
		
		"cover":       { "skip": "<div class=\"relative contents\" itemprop=\"image\"", "token1": "src=\"", "token2": "\"" },
		
		
		
		
		"add_genre":   { "after": "itemprop=\"genre\"",  "token1": "\">", "token2": "</",
                            "replace": { "match":"<.*?>","text":" "} },
		
		"chapters_from_page": { "skip": "<div id=\"chapter-list\"", "token1": "manga_id=", "token2": "&",
			"replace":  [
			{"prefix": "https://rawkuma.net/wp-admin/admin-ajax.php?manga_id="},
			{"sufix": "&page=1&action=chapter_list"}
			]
			},
			
			
			
		"add_chapter": {
			"next":  "<div data-chapter-number=",
			"link":  { "token1": "href=\"", "token2": "\""   },
			"uniq":  { "token1": "<a href=\"https://rawkuma.net/manga/", "token2": "\"","replace": {"prefix" : "https://rawkuma.net/manga/" }   },
			"title": { "skip": "<a href=\"https://rawkuma.net/manga/",  "token1": "<span>", "token2": "</span>",
				"replace" : { "match" : "&nbsp;&nbsp;","text":" " }
			}
		}   
	},
	"chapter_complete": {
	"add_images": {
			"start": "<div class=\"mx-4 md:mx-0\">",
			 "end": "</section>",
			"token1": "src='",
			"token2": "'",
			"replace": { "match": "\\\\", "text": "" }
		}
	},

