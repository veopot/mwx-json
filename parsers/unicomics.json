{   
    "id": 30431,
	"version": 14,
	"old_ids": [15619],
   
	"title": "UniComics",
	"host": "https://unicomics.ru/",
	"public_link": "https://unicomics.ru/comics/online",
	"folder": "unicomics",
	"name" : "unicomics",
	"language": "ru",
	"is_paid": true,
	
	"icon_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/img/unicomics.png",
	"self_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/parsers/unicomics.json",
	"self_link2": "https://fant.my1.ru/mwparser/mwx/json/unicomics.json",
	"catalog_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/catalogs/unicomics.zip",
    "file_type": "sqlite",

	

	"manga_list_complete": {
	"headers": {
        "accept": "*/*",
        "referer": "https://unicomics.ru/"
    },		
		"iterator": {
			"base_url": "https://unicomics.ru/comics/series/page/",
			"append_nums": { "from": 1, "to": 119 }
		},
		"add_manga": { 
			"next": "class=\"comic-card\">",
			"link":  { "token1": "href=\"", "token2": "\"" }, 
			
			"uniq":  { "token1": "href=\"/comics/series/", "token2": "\"" }, 
			
			"title": { "after": "href=\"",
			"token1": "class=\"comic-title-link\">", "token2": "</a>",
        "replace": [
          { "match": "<div class=\"comic-title-ru\">", "text": "" },
		  { "match": "<div class=\"comic-title-en\">", "text": " | " },
          { "match": "</div>", "text": "" }
        ] 
		}
		
		
		},
		"rating_auto_inc": {
			"start": "10000",
			"inc": -1
		}
	},

	"manga_complete": {
	"headers": {
        "accept": "*/*",
        "referer": "https://unicomics.ru/"
    },
	
		"title":       { "token1": "<title>", "token2": "</title>",
			"replace" : { "match" : "- Серии комиксов | UniComics", "text" : "" } },
		
		"uniq": { "skip": "<div class=\"info\">", "token1": "<h2>", "token2": "</" },
		"summary": { "skip": "<b>Описание серии комиксов:", "token1": "</b>", "token2": "</div>",
		
				    "replace": { "match" : "<.*?>", "text" : "" } },
					
		"author": { "skip": ">Издательство:<", "token1": "\">", "token2": "</",
			"replace" : { "match" : "<.*?>", "text" : "" } },
		
		
		"cover":       { 
			"after": "image center", 
			"token1": "<img src=\"", 
			"token2": "\""
		},
		"add_tag":   { "after": "<a href=\"search/1030-1/",
	  "token1": ">", "token2": "</" , "replace": { "match": "<.*?>", "text": "" }},
		
		"chapters_from_page": {
			"before": "class=\"btn-read-first\"",
			"token1": "<a href=\"",
			"token2": "\""
		},
		"add_chapter": {
			"headers": {
        "accept": "*/*",
        "referer": "https://unicomics.ru/"
    },
			"start": "class=\"modal-list\">",
			"next":  "<a href", 
			"link":  { "token1": "=\"", "token2": "\"", "replace": { "prefix": "https://unicomics.ru/"} }, 
			"title": { "token1": "title=\"", "token2": "\"" },
			"end": "</div>"
		}
	},
	"chapter_complete": {
	"headers": {
        "accept": "*/*",
        "referer": "https://unicomics.ru/"
    },
	
		"add_pages": { 
			"start": "new Paginator", 
			"token1": "\"/", 
			"token2": "\")", 
			"end": "script>",
			"scans_count": { "token1": "\"paginator1\", ", "token2": "," },
			"replace" : { "prefix" : "https://unicomics.ru/" }
		}
	},
	"page_complete": {
	"headers": {
        "accept": "*/*",
        "referer": "https://unicomics.ru/"
    },
		"image": { "after": "id=\"image\"", "token1": "src=\"", "token2": "\"" }
	},

	"test": [
		{
			"proc" : "manga_list_complete",
			"assert" : {
				"mangas": [
					{ 
						"title": "Её Собственный Дар",
						"link": "https://unicomics.ru/comics/series/a-gift-of-her-own",
						 "uniq": "a-gift-of-her-own"
					}
				],
				"mangas_count" : ">22"
			}
		},
		{
			"proc" : "manga_complete",
			          
			"link" : "https://unicomics.ru/comics/series/100-bullets",
			"title" : "100 Пуль",
			"assert" : {
				"author" : "@Vertigo",
				"cover" : "https://unicomics.ru/img/comics/p/100-bullets/100-bullets-001_big.jpg",
			    "status" : "ongoing",
				"genres": "@action",
				"chapters_count" : ">=50",
				"chapters" : [
					{   
					"title": "100 Bullets #1",
					"link" : "https://unicomics.ru/comics/online/100-bullets-001",
					"folder": "00-bullets-001/"
					},
					{ "link": "https://unicomics.ru/comics/online/age-of-apocalypse-2015-3" }
				]
			}
		},
		{
			"proc" : "chapter_complete",
			"link" : "https://unicomics.ru/comics/online/100-bullets-100",
			 "assert" : {
				"pages" : [
		{"link": "https://unicomics.ru/comics/online/age-of-apocalypse-2015-1/1"},
        {"link": "https://unicomics.ru/comics/online/age-of-apocalypse-2015-1/2"},
        {"link": "https://unicomics.ru/comics/online/age-of-apocalypse-2015-1/3"},
        {"link": "https://unicomics.ru/comics/online/age-of-apocalypse-2015-1/4"}
				]
			}
		},
		{
			"proc" : "page_complete",
			"link" : "https://unicomics.ru/comics/online/age-of-apocalypse-2015-1/4",
			"assert" : {
				"image" : "https://img1.unicomics.com/comics/age-of-apocalypse-2015/age-of-apocalypse-2015-1/04.jpg"
			}
		}
	]
}