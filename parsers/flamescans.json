{
    "id": 80001,
    "version": 6,
    "old_sites": [ "flamecomics.me" ],
	
    "title": "Flame Comics",
    "host": "https://flamecomics.xyz/",
    "public_link": "https://flamecomics.xyz/series/",
    "name": "flamescans",
    "folder": "flamescans",
    "language": "en",

    "icon_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/img/flamescans.png",
    "self_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/parsers/flamescans.json",
    "catalog_link": "https://raw.githubusercontent.com/veopot/mwx-json/main/catalogs/flamescans.zip",
    "file_type": "sqlite",

    "manga_list_complete": {
        "headers": {
            "Referer": "https://flamecomics.xyz/"
        },
        "iterator": "https://flamecomics.xyz/api/series",
        "add_manga": {
            "start": "[",
            "end": "}]",
            "next": "{\"i",

            "link": {
                "token1": "d\":",
                "token2": ",",
				"replace": {
					"prefix": "https://flamecomics.xyz/series/"
				}
				
            },
            "uniq": {
                "token1": "d\":",
                "token2": ",",
            },
            "title": {
                "token1": "\"label\":\"",
                "token2": "\""
            }
        }
    },

    "manga_complete": {
        "title": {
            "after": "<meta property=\"og:title\"",
            "token1": "content=\"",
            "token2": "\""
        },

        "uniq": {
            "after": "<meta property=\"og:title\"",
            "token1": "content=\"",
            "token2": "\""
        },

        "summary": {
            "token1": "\"description\":\"",
            "token2": "\"",
            "replace": [
                {
                    "clear_escape": true
                },
                {
                    "clear_html": true
                }
            ]
        },

        "author": {
            "after": ">Author</",
            "token1": "p>",
            "token2": "</div>",
            "replace": [
                {
                    "clear_escape": true
                },
                {
                    "clear_html": true
                }
            ]
        },

        "status": {
			
			"unknown": "\"status\":\"Dropped\"",
            "complete": "\"status\":\"Completed\"",
            "ongoing": "\"status\":\"Ongoing\""
        },

        

        "cover": {
            "after": "<meta name=\"twitter:image\"",
            "token1": "content=\"",
            "token2": "\"",
            "replace": [
                {
                    "clear_escape": true
                },
                {
                    "clear_html": true
                }
            ]
        },

        "add_tag": {
            "after": "href=\"/genre/", 
            "token1": "label\">",
            "token2": "</span>"
        },

        "add_chapter": {
            "start": "\"chapters\":",
            "end": "</body>",
			
            "next": "\"chapter_id\"",
			
			
            "link": {
                "token1": "\"token\":\"",
                "token2": "\"",
				"replace": {
					"prefix": "%%url%%/"
				}
				
			}, 
            "uniq": {
                "token1": "\"chapter\":\"",
                "token2": "\"",
                "replace": [{
                        "match": ".0",
                        "text": ""
                    }, 
					{ "prefix": "Chapter "
                    }
                ]
            },
            "title": {
                "token1": "\"chapter\":\"",
                "token2": "\"",
                "replace": [{
                        "match": ".0",
                        "text": ""
                    }, 
					{ "prefix": "Chapter "
                    }
                ]
            }
        }
    },


    "chapter_complete": {
        "images": true,
        "add_pages": {
            "start": "data-line-clamp=\"true\">",
			
			"token1": "src=\"https://cdn.flamecomics.xyz/uploads/images/series/",
            "token2": "\"",
            "end": "<img alt=\"commission\"",
            "replace":{ "prefix": "https://cdn.flamecomics.xyz/uploads/images/series/"}
              
		}
    },

    "test": [{
            "proc": "manga_list_complete",
            "assert": {
                "mangas": [{
                        "title": "48 Hours a Day",
                        "link": "https://flamecomics.xyz/series/forty-eight-hours-a-day/"

                    }
                ],
                "mangas_count": ">60"
            }
        }, {
            "proc": "manga_complete",
            "title": "48 Hours a Day",
            "link": "https://flamecomics.xyz/series/99",
            "assert": {
                "author": "@Little Bleary Zhao",
                "cover": "https://flamecomics.xyz/wp-content/uploads/2022/06/unknown-1.png",
                "summary": "@^(The God of Time)",
                "tags": "@action",
                "status": "unknown",
                "tags_count": ">2",
                "chapters_count": ">40",
                "chapters": [
		{
            "link": "https://flamecomics.xyz/series/99/596241414bde1e53",
            "title": "Chapter 1"
        },
        {
            "link": "https://flamecomics.xyz/series/99/06065dc6f9d3320e",
            "title": "Chapter 2"
        }
                ]
            }
        }, {
            "proc": "chapter_complete",
            "link": "https://flamecomics.xyz/series/99/596241414bde1e53",
            "assert": {
                "pages": [
		 {"image": "https://cdn.flamecomics.xyz/uploads/images/series/99/596241414bde1e53/FEHD1-1.jpg?1732310173"},
        {"image": "https://cdn.flamecomics.xyz/uploads/images/series/99/596241414bde1e53/FEHD1-2.jpg?1732310173"},
        {"image": "https://cdn.flamecomics.xyz/uploads/images/series/99/596241414bde1e53/FEHD1-3.jpg?1732310173"},
        {"image": "https://cdn.flamecomics.xyz/uploads/images/series/99/596241414bde1e53/FEHD1-4.jpg?1732310173"},
                ],
                "pages_count": "22"
            }
        }
    ]
}
